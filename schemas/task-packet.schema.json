{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://factory.local/schemas/task-packet.schema.json",
  "title": "TaskPacket",
  "type": "object",
  "required": [
    "schemaVersion",
    "taskId",
    "projectKey",
    "title",
    "type",
    "priority",
    "riskLevel",
    "lifecycleStage",
    "acceptanceCriteria",
    "constraints",
    "approvalsNeeded",
    "relevantFiles",
    "ownerAgent",
    "nextAgent",
    "audit",
    "rollback"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "taskId": {
      "type": "string",
      "pattern": "^[A-Z]+-[0-9]{8}-[0-9]{3}$"
    },
    "projectKey": {
      "type": "string",
      "pattern": "^[a-z0-9-]{2,32}$"
    },
    "title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 200
    },
    "description": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "feature",
        "bugfix",
        "refactor",
        "security",
        "infra",
        "docs",
        "release"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "P0",
        "P1",
        "P2",
        "P3"
      ]
    },
    "riskLevel": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "lifecycleStage": {
      "type": "string",
      "enum": [
        "intake",
        "breakdown",
        "assignment",
        "implementation",
        "review",
        "release",
        "done",
        "blocked"
      ]
    },
    "acceptanceCriteria": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "approvalsNeeded": {
      "type": "object",
      "required": [
        "merge",
        "deploy",
        "securityReview",
        "humanApproval"
      ],
      "properties": {
        "merge": {
          "type": "boolean"
        },
        "deploy": {
          "type": "boolean"
        },
        "securityReview": {
          "type": "boolean"
        },
        "humanApproval": {
          "type": "boolean"
        }
      }
    },
    "relevantFiles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ownerAgent": {
      "type": "string"
    },
    "nextAgent": {
      "type": "string"
    },
    "branch": {
      "type": "object",
      "required": [
        "base",
        "name"
      ],
      "properties": {
        "base": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "rollback": {
      "type": "object",
      "required": [
        "plan",
        "notes"
      ],
      "properties": {
        "plan": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "audit": {
      "type": "object",
      "required": [
        "createdBy",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "createdBy": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
